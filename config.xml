<?xml version='1.0' encoding='utf-8'?>
<widget id="com.dps.inventory" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>DPS-INVENTORY</name>
    <description>
        Offline-first mobile inventory management app. Barcode/QR scanning,
        stock in/out tracking, and printable reports — all 100% offline
        using IndexedDB for local storage.
    </description>
    <author email="support@example.com" href="https://example.com">
        DPS-INVENTORY Team
    </author>

    <content src="index.html" />

    <!-- No network permissions are required — the app never calls the internet. -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <preference name="DisallowOverscroll" value="true" />
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <preference name="BackgroundColor" value="0xFFFFFFFF" />
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />
    <preference name="AndroidXEnabled" value="true" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <preference name="StatusBarBackgroundColor" value="#A11D2E" />

    <platform name="android">
        <allow-intent href="market:*" />

        <!-- Camera permission is required for offline barcode/QR scanning -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-feature android:name="android.hardware.camera" android:required="false" />
            <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
        </config-file>

        <icon density="ldpi" src="res/android/icon-ldpi.png" />
        <icon density="mdpi" src="res/android/icon-mdpi.png" />
        <icon density="hdpi" src="res/android/icon-hdpi.png" />
        <icon density="xhdpi" src="res/android/icon-xhdpi.png" />
        <icon density="xxhdpi" src="res/android/icon-xxhdpi.png" />
        <icon density="xxxhdpi" src="res/android/icon-xxxhdpi.png" />
    </platform>

    <plugin name="cordova-plugin-camera" spec="^7.0.0" />
    <plugin name="cordova-plugin-file" spec="^8.1.0" />
    <plugin name="cordova-plugin-android-permissions" spec="^1.1.5" />

    <engine name="android" spec="^12.0.0" />
</widget>
